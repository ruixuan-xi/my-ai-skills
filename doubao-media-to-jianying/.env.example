# 火山引擎方舟 API Key（控制台直接创建）
ARK_API_KEY=your_api_key_here

VOLC_REGION=cn-beijing

# 推理接入点 ID（Endpoint ID）
# 对话/文案生成模型（如 doubao-pro-32k）
CHAT_MODEL_ID=ep-xxxxxxxx-xxxxx

# 文生图模型（如 doubao-seedream-3-0-t2i-250415）
IMAGE_MODEL_ID=ep-xxxxxxxx-xxxxx

# 文生视频模型（如 doubao-seaweed-241128）
VIDEO_MODEL_ID=ep-xxxxxxxx-xxxxx

# TTS 语音合成（可选，若不用 TTS 可留空）
# 注意：TTS_ACCESS_TOKEN 在语音合成控制台获取，与方舟 API Key 不同
# 大模型语音合成使用 V3 接口，TTS_CLUSTER 填 volc.service_type.10029
# 可用音色: zh_female_shuangkuaisisi_moon_bigtts, zh_female_roumeinvyou_emo_v2_mars_bigtts 等
TTS_APP_ID=
TTS_ACCESS_TOKEN=
TTS_CLUSTER=volc.service_type.10029

# ====================== 计费单价（纯数字，必须换算后填入）======================
# 注意：所有单价字段只能填纯数字，不能带中文单位说明
#
# 文案模型单价（单位：元/千tokens）
#   换算示例：2元/百万tokens → 0.002；8元/百万tokens → 0.008
CHAT_INPUT_PRICE=0.002
CHAT_OUTPUT_PRICE=0.003

# TTS 语音合成单价（单位：元/万字符）
#   换算示例：0.0005元/字符 → 0.0005 × 10000 = 5.0
TTS_PRICE_PER_10K=5.0

# 文生图单价（单位：元/张）
IMAGE_PRICE=0.25

# 文生视频单价（单位：元/百万tokens）
#   有声视频（含语音/音效）：16
#   无声视频（纯画面）：8
VIDEO_PRICE_AUDIO=16.0
VIDEO_PRICE_SILENT=8.0

# ====================== 剪映草稿目录 ======================
# 剪映专业版草稿保存路径（一般在用户 AppData 下）
JIANYING_DRAFT_PATH=C:\Users\{用户名}\AppData\Local\JianyingPro\User Data\Projects\com.lveditor.draft

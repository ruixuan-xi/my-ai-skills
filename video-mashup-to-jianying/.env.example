# 火山引擎方舟 API Key（控制台直接创建）
ARK_API_KEY=your_api_key_here

VOLC_REGION=cn-beijing

# 视觉理解模型（用于视频画面分析 + 卖货文案生成）
# 推荐：doubao-1.5-vision-pro-32k-250115（支持图片/视频理解）
# 备选：doubao-1.5-vision-pro-32k、doubao-vision-pro-32k
VISION_MODEL_ID=doubao-1.5-vision-pro-32k-250115

# 文本模型（用于连贯文案生成，汇总视频画面分析后一次性生成有起承转合的卖货脚本）
CHAT_MODEL_ID=ep-xxxxxxxx-xxxxx

# TTS 语音合成（可选，若不用 TTS 可留空）
# 注意：TTS_ACCESS_TOKEN 在语音合成控制台获取，与方舟 API Key 不同
# 大模型语音合成使用 V3 接口
# 1.0 音色(moon/mars_bigtts): TTS_RESOURCE_ID=volc.service_type.10029
# 2.0 音色(uranus_bigtts): TTS_RESOURCE_ID=seed-tts-2.0
TTS_APP_ID=
TTS_ACCESS_TOKEN=
TTS_CLUSTER=volc.service_type.10029

# 音色选择（卖货推荐）：
# zh_female_kailangjiejie_uranus_bigtts - 开朗姐姐2.0, 开朗亲切, 适合互动卖货
# zh_female_shuangkuaisisi_uranus_bigtts - 爽快思思2.0, 爽快风格, 适合快节奏卖货
# zh_female_linxiao_uranus_bigtts - 林潇2.0, 抖音同款
TTS_VOICE=zh_female_kailangjiejie_uranus_bigtts
TTS_RESOURCE_ID=seed-tts-2.0

# 语速控制 speech_rate: [-50,100], 0=正常, 100=2.0倍速, -50=0.5倍速
# 公式: (目标倍速-1.0)*100, 如 1.25倍速=25, 1.5倍速=50
TTS_SPEECH_RATE=25

# ====================== 计费单价（纯数字，必须换算后填入）======================
# 注意：所有单价字段只能填纯数字，不能带中文单位说明
#
# 视觉理解模型单价（单位：元/千tokens）
#   换算示例：3元/百万tokens → 0.003；9元/百万tokens → 0.009
VISION_INPUT_PRICE=0.003
VISION_OUTPUT_PRICE=0.009

# 文本模型单价（元/千tokens）— 用于连贯文案生成
CHAT_INPUT_PRICE=0.0008
CHAT_OUTPUT_PRICE=0.002

# TTS 语音合成单价（单位：元/万字符）
#   换算示例：0.0005元/字符 → 0.0005 × 10000 = 5.0
TTS_PRICE_PER_10K=5.0

# ====================== 剪映草稿目录 ======================
# 剪映专业版草稿保存路径（一般在用户 AppData 下）
JIANYING_DRAFT_PATH=C:\Users\{用户名}\AppData\Local\JianyingPro\User Data\Projects\com.lveditor.draft
